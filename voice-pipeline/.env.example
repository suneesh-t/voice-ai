# ──────────────────────────────────────────────
# STT (Speech-to-Text) Provider
# ──────────────────────────────────────────────
# Options:
#   "cohere"  → CohereLabs/cohere-transcribe-03-2026 (default)
#   "whisper" → openai/whisper-large-v3-turbo
STT_PROVIDER=cohere

# CohereLabs/cohere-transcribe-03-2026
COHERE_STT_URL=http://localhost:8000

# openai/whisper-large-v3-turbo
WHISPER_STT_URL=http://localhost:8003
WHISPER_LANGUAGE=en

# ──────────────────────────────────────────────
# TTS (Text-to-Speech) Provider
# ──────────────────────────────────────────────
# Options:
#   "qwen3"     → Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice (default)
#   "omnivoice" → k2-fsa/OmniVoice
#   "kokoro"    → hexgrad/Kokoro-82M
TTS_PROVIDER=qwen3

# Qwen/Qwen3-TTS-12Hz-1.7B-CustomVoice
QWEN3_TTS_URL=http://localhost:8001
TTS_VOICE=vivian
TTS_LANGUAGE=Auto

# k2-fsa/OmniVoice
OMNIVOICE_TTS_URL=http://localhost:8002
OMNIVOICE_INSTRUCT=
OMNIVOICE_SPEED=1.0

# hexgrad/Kokoro-82M
KOKORO_TTS_URL=http://localhost:8004
KOKORO_VOICE=af_heart
# Optional — otherwise inferred from voice prefix (e.g. 'a' = American English)
KOKORO_LANG_CODE=
KOKORO_SPEED=1.0

# ──────────────────────────────────────────────
# LLM Provider
# ──────────────────────────────────────────────
# Amazon Bedrock
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=<your-bedrock-model-id>
